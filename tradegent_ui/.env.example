# Tradegent Agent UI - Environment Variables

# LLM Configuration
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-your-api-key
LLM_MODEL=google/gemini-2.0-flash-001

# MCP Servers
IB_MCP_URL=http://localhost:8100/mcp
RAG_MCP_CMD=python -m tradegent.rag.mcp_server
GRAPH_MCP_CMD=python -m tradegent.graph.mcp_server
MCP_CWD=/opt/data/tradegent_swarm

# PostgreSQL
PG_HOST=localhost
PG_PORT=5433
PG_USER=tradegent
PG_PASS=your_password
PG_DB=tradegent

# Neo4j (for Graph)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASS=your_password

# Server
AGUI_HOST=0.0.0.0
AGUI_PORT=8081
FRONTEND_URL=http://localhost:3000

# =============================================================================
# ADMIN USER (Superuser) - REQUIRED
# Similar to PostgreSQL's postgres user. Authentication is ALWAYS enabled.
# =============================================================================
ADMIN_EMAIL=admin@tradegent.local
ADMIN_PASSWORD=<CHANGE_THIS_REQUIRED>
ADMIN_NAME=System Administrator

# JWT Secret (REQUIRED) - Generate with: openssl rand -base64 32
JWT_SECRET=<CHANGE_THIS_REQUIRED>

# Demo Account (optional, for testing)
DEMO_EMAIL=demo@tradegent.local
DEMO_PASSWORD=<CHANGE_THIS_OPTIONAL>

# Feature Flags
DEBUG=false
