# ═══════════════════════════════════════════════════════════════
# Tradegent Platform v2.2 - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# SECURITY: Copy this file to .env and fill in your values
#           NEVER commit .env to version control
#
# To generate strong passwords: openssl rand -base64 24
# To generate tokens: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────
# INTERACTIVE BROKERS
# ─────────────────────────────────────────────────

# Paper trading account credentials
# Get from: https://www.interactivebrokers.com/
IB_USER=<your-ib-username>
IB_PASS=<your-ib-password>
IB_ACCOUNT=<your-paper-account-id>

# VNC password for IB Gateway UI access (generate unique password)
VNC_PASS=<generate-strong-password>

# ─────────────────────────────────────────────────
# LLM PROVIDERS (Recommended: OpenAI for both)
# ─────────────────────────────────────────────────

# Provider options: ollama, openai, openrouter, claude_api
EMBED_PROVIDER=openai
EXTRACT_PROVIDER=openai

# OpenAI API Key (required for openai provider)
# Get from: https://platform.openai.com/api-keys
# Cost: ~$2/year for embeddings + extraction
OPENAI_API_KEY=<your-openai-api-key>

# Optional: Anthropic API Key (for Claude Code API auth)
# ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Optional: OpenRouter API Key (alternative to direct OpenAI)
# OPENROUTER_API_KEY=<your-openrouter-api-key>

# ─────────────────────────────────────────────────
# LITELLM SHARED ROUTING (Track E)
# ─────────────────────────────────────────────────

# Default model used when a role route is not explicitly configured.
LLM_MODEL=gpt-4o-mini

# Enable shared LiteLLM path for ADK sub-agent phases.
# false: emit route metadata only (safe default)
# true: execute sub-agent calls through LiteLLM shared gateway
ADK_SUBAGENT_LLM_ENABLED=false

# Skill-native adapter rollout controls (defaults: disabled)
ADK_SKILL_NATIVE_STOCK_ENABLED=false
ADK_SKILL_NATIVE_EARNINGS_ENABLED=false
ADK_SKILL_NATIVE_CANARY_PERCENT=0
ADK_SKILL_NATIVE_KILL_SWITCH=false
ADK_SKILL_NATIVE_CANARY_STAGE_ENFORCED=false

# Role-based routing chains (ordered, deterministic fallback).
# Format: provider/model,provider/model
LITELLM_ROUTE_REASONING_PREMIUM=openai/gpt-4o
LITELLM_ROUTE_REASONING_STANDARD=openrouter/openai/gpt-4o-mini,openai/gpt-4o-mini
LITELLM_ROUTE_EXTRACTION_FAST=openai/gpt-4o-mini
LITELLM_ROUTE_CRITIC_MODEL=openai/gpt-4o-mini
LITELLM_ROUTE_SUMMARIZER_FAST=openai/gpt-4o-mini

# Optional global fallback chain appended to each role route.
# Example:
# LITELLM_FALLBACK_MODELS=openrouter/openai/gpt-4o-mini,openai/gpt-4o-mini
LITELLM_FALLBACK_MODELS=

# Market-data hard quality gates for stock-analysis write path.
# Default: enabled and blocking for production-safe stock artifact quality.
ADK_MARKET_DATA_GATES_ENABLED=true
ADK_MARKET_DATA_GATES_BLOCKING=true
ADK_MARKET_DATA_ALLOWED_SOURCES=ib_gateway,ib_mcp
ADK_MARKET_DATA_MAX_STALENESS_SEC=120
ADK_MARKET_DATA_MAX_DEVIATION_PCT=20

# Template version pinning (wave-1 skills)
# Selection priority at runtime:
# 1) ADK_TEMPLATE_VERSION_<SKILL>
# 2) ADK_TEMPLATE_VERSION (global)
# 3) highest template.vX.Y.yaml, then template.yaml fallback
#
# Valid values: 2.6, 2.7, 2.8, 2.8.0 (normalized to major.minor)
# Leave empty to disable pinning and use default auto-selection.
ADK_TEMPLATE_VERSION=
ADK_TEMPLATE_VERSION_STOCK_ANALYSIS=
ADK_TEMPLATE_VERSION_EARNINGS_ANALYSIS=
ADK_TEMPLATE_VERSION_SCAN=
ADK_TEMPLATE_VERSION_WATCHLIST=

# Rollout presets (examples):
# Production conservative pin:
# ADK_TEMPLATE_VERSION_STOCK_ANALYSIS=2.7
# ADK_TEMPLATE_VERSION_EARNINGS_ANALYSIS=2.6
#
# Staging / canary pin to latest:
# ADK_TEMPLATE_VERSION=2.8

# ─────────────────────────────────────────────────
# OLLAMA FALLBACK (Local, free, slower)
# ─────────────────────────────────────────────────

# Uncomment to use Ollama instead of OpenAI:
# EMBED_PROVIDER=ollama
# EXTRACT_PROVIDER=ollama
# LLM_MODEL=qwen3:8b
# EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────────────
# DATABASE CREDENTIALS
# ─────────────────────────────────────────────────

# PostgreSQL (pgvector for RAG embeddings)
PG_USER=tradegent
PG_PASS=<generate-strong-password>
PG_DB=tradegent
PG_HOST=localhost
PG_PORT=5433

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASS=<generate-strong-password>

# Timezone synchronization (pipeline + DB session)
# Tradegent uses this timezone for market-aware datetime handling.
TRADEGENT_TIMEZONE=America/New_York
# PostgreSQL session timezone for all DB writes/reads (defaults to TRADEGENT_TIMEZONE).
PG_TIMEZONE=America/New_York

# ─────────────────────────────────────────────────
# SERVICE CONFIGURATION
# ─────────────────────────────────────────────────

# Orchestration runtime engine (ADK-only)
# Allowed value: adk
AGENT_ENGINE=adk

# Health endpoint (binds to localhost by default for security)
HEALTH_PORT=8080
HEALTH_BIND_ADDR=127.0.0.1

# Optional: Token for authenticated health check access
# Required to see detailed metrics; without it, only status is exposed
# HEALTH_CHECK_TOKEN=<generate-random-token>

# ─────────────────────────────────────────────────
# ORCHESTRATOR LIMITS
# ─────────────────────────────────────────────────

MAX_DAILY_ANALYSES=15
MAX_DAILY_EXECUTIONS=5
CLAUDE_TIMEOUT=600
